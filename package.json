{
  "name": "lecture-site-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "validate": "node --import ./scripts/register-ts-loader.mjs scripts/validate.ts",
    "package:review": "node --import ./scripts/register-ts-loader.mjs scripts/packageReview.ts"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "tsx": "4.22.5",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
